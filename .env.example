# =============================================================================
# VALIANT PROSPECTOR — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# PostgreSQL
POSTGRES_USER=valiant
POSTGRES_PASSWORD=changeme_strong_password

# JWT Authentication (min 32 chars)
JWT_SECRET=changeme_jwt_secret_min_32_chars_here

# OpenAI
OPENAI_API_KEY=sk-...

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Apollo.io (LinkedIn fallback for stakeholder discovery)
APOLLO_API_KEY=

# Hunter.io (email finder)
HUNTER_API_KEY=

# Evolution API (WhatsApp) — acessível em http://localhost:8081
EVOLUTION_API_KEY=changeme_evolution_key

# SendGrid (Email)
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=prospector@exemplo.com.br

# MinIO / S3-compatible storage — console em http://localhost:9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_password

# API
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Asynqmon (painel de filas)
ASYNQMON_USER=admin
ASYNQMON_PASSWORD=changeme_asynqmon_password

# Playwright service
BROWSER_POOL_SIZE=5

# Traefik (profile edge)
TRAEFIK_ACME_EMAIL=devops@exemplo.com
TRAEFIK_APP_HOST=app.exemplo.com
TRAEFIK_API_HOST=api.exemplo.com

# Seed admin (make seed-admin)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=troque_esta_senha

# Frontend → API (usado pelo Next.js no browser)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Optional: HTTP proxy para scraping (ex: http://user:pass@proxy:port)
PROXY_URL=
